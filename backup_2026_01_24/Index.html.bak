                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                    <polyline points="7 10 12 15 17 10"></polyline>
                                    <line x1="12" y1="15" x2="12" y2="3"></line>
                                </svg>
                                Export Data
                            </button>
                            <button onclick="openModal('add')"
                                class="px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-lg shadow-indigo-200 flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <line x1="12" y1="5" x2="12" y2="19"></line>
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                </svg>
                                Tambah Karyawan
                            </button>
                        </div>
                    </div>

                    <!-- Tabs & Search Row -->
                    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4">
                        <!-- Custom Tabs -->
                        <div class="flex flex-wrap items-center gap-2" id="certification-tabs">
                            <button onclick="switchTab(this, 'all')"
                                class="tab-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all bg-indigo-600 text-white shadow-sm ring-1 ring-indigo-600">
                                Semua
                            </button>
                            <button onclick="switchTab(this, 'active')"
                                class="tab-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all bg-white text-gray-600 hover:text-gray-900 border border-gray-200 hover:border-gray-300">
                                Aktif
                            </button>
                            <button onclick="switchTab(this, 'expiring')"
                                class="tab-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all bg-white text-gray-600 hover:text-gray-900 border border-gray-200 hover:border-gray-300">
                                Segera Kadaluarsa
                            </button>
                            <button onclick="switchTab(this, 'inactive')"
                                class="tab-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all bg-white text-gray-600 hover:text-gray-900 border border-gray-200 hover:border-gray-300">
                                Tidak Aktif
                            </button>
                            <button onclick="switchTab(this, 'renewal')"
                                class="tab-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all bg-white text-gray-600 hover:text-gray-900 border border-gray-200 hover:border-gray-300">
                                Perpanjangan
                            </button>
                        </div>

                        <!-- Search Box -->
                        <div class="relative w-full lg:w-72">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none"
                                    viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                </svg>
                            </div>
                            <input type="text" id="searchInput" oninput="applyFilters()"
                                placeholder="Search employee..."
                                class="w-full pl-10 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:bg-white transition-all">
                        </div>
                    </div>

                    <!-- Filters Row -->
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
                        <select id="filter-unit" onchange="applyFilters()"
                            class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-indigo-500 hover:bg-white cursor-pointer transition-colors">
                            <option value="">Semua Unit</option>
                            <!-- Populated by JS -->
                        </select>
                        <select id="filter-anggaran" onchange="applyFilters()"
                            class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-indigo-500 hover:bg-white cursor-pointer transition-colors">
                            <option value="">Semua Status Anggaran</option>
                            <option value="Tersedia">Tersedia</option>
                            <option value="Tidak Tersedia">Tidak Tersedia</option>
                        </select>


                        <div class="flex items-center">
                            <button onclick="resetFilters()"
                                class="text-sm font-medium text-gray-500 hover:text-indigo-600 flex items-center gap-1.5 transition-colors ml-auto md:ml-0">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 12"></path>
                                    <path d="M3 3l0 9l9 0"></path>
                                </svg>
                                Reset Filter
                            </button>
                        </div>
                    </div>
                </div>

                <!-- 3. Table -->
                <!-- 3. List Header & Content -->
                <div class="space-y-4">
                    <!-- List Header -->
                    <div
                        class="hidden md:flex bg-gray-50/50 border-b border-gray-100 px-6 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">
                        <div class="w-16">SAP</div>
                        <div class="flex-1">Nama Karyawan</div>
                        <div class="w-1/3 text-right pr-12">Unit Kerja</div>
                    </div>

                    <!-- CONTAINER FOR ACCORDION LIST -->
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">


                        <!-- CONTAINER FOR ACCORDION LIST -->
                        <!-- CONTAINER FOR ACCORDION LIST -->
                        <div id="accordion-container" class="space-y-4 min-h-[400px] relative">
                            <!-- Loading State handled by JS -->
                            <div id="loading-spinner"
                                class="text-center py-12 absolute inset-0 flex flex-col items-center justify-center bg-white z-10">
                                <svg class="animate-spin h-8 w-8 text-indigo-500 mx-auto mb-4"
                                    xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor"
                                        stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor"
                                        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
                                    </path>
                                </svg>
                                <p class="text-gray-500 text-sm mb-4">Memuat daftar karyawan...</p>
                                <button id="retry-button" type="button" onclick="forceLoadOffline()"
                                    class="hidden px-4 py-2 bg-indigo-100 text-indigo-700 rounded-lg text-sm font-medium hover:bg-indigo-200 transition-colors cursor-pointer">
                                    Gunakan Data Offline
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SUB-PAGE: Perencanaan LAT -->
                <div id="page-perencanaan-lat" class="content-section" style="display: none;">
                    <div
                        style="padding: 40px; border: 2px dashed #10b981; border-radius: 16px; display: flex; align-items: center; justify-content: center; height: 400px; color: #10b981; background-color: #ecfdf5; text-align: center;">
                        <div>
                            <h3 style="margin-bottom: 8px; font-weight: 500;">Perencanaan LAT</h3>
                            <p style="font-size: 14px;">Form dan Tabel Perencanaan LAT.</p>
                            <button
                                onclick="setActive(document.querySelector('a[onclick*=\'page-data-sertifikat\']'), 'Perencanaan', 'page-data-sertifikat')"
                                style="margin-top: 16px; padding: 8px 16px; background: #10b981; color: white; border: none; border-radius: 6px; cursor: pointer;">Kembali</button>
                        </div>
                    </div>
                </div>

                <script>
                    function openSubPage(pageId, title) {
                        // Hide all content sections
                        const sections = document.querySelectorAll('.content-section');
                        sections.forEach(section => section.style.display = 'none');

                        // Show target
                        const target = document.getElementById(pageId);
                        if (target) target.style.display = 'block';

                        // Update Header
                        const titleEl = document.getElementById('page-title');
                        const descEl = document.getElementById('page-description');
                        if (titleEl) titleEl.innerText = title;
                        if (descEl) descEl.innerText = 'Mengelola ' + title;
                    }
                </script>

                <!-- PAGE: Pelaksanaan LND -->
                <div id="page-data-sertifikasi-lat" class="content-section" style="display: none;">
                    <div
                        style="padding: 40px; border: 2px dashed #ec4899; border-radius: 16px; display: flex; align-items: center; justify-content: center; height: 400px; color: #ec4899; background-color: #fce7f3; text-align: center;">
                        <div>
                            <h3 style="margin-bottom: 8px; font-weight: 500;">Pelaksanaan LND</h3>
                            <p style="font-size: 14px;">Data pelaksanaan LND akan ditampilkan di sini.</p>
                        </div>
                    </div>
                </div>

                <!-- PAGE: ANALISIS -->
                <div id="page-analisis" class="content-section" style="display: none;">
                    <div
                        style="padding: 40px; border: 2px dashed #f59e0b; border-radius: 16px; display: flex; align-items: center; justify-content: center; height: 400px; color: #f59e0b; background-color: #fffbeb; text-align: center;">
                        <div>
                            <h3 style="margin-bottom: 8px; font-weight: 500;">Analisis Data</h3>
                            <p style="font-size: 14px;">Grafik dan visualisasi data akan ditampilkan di sini.</p>
                        </div>
                    </div>
                </div>

                <!-- PAGE: LAPORAN -->
                <div id="page-laporan" class="content-section" style="display: none;">
                    <div
                        style="padding: 40px; border: 2px dashed #6366f1; border-radius: 16px; display: flex; align-items: center; justify-content: center; height: 400px; color: #6366f1; background-color: #eef2ff; text-align: center;">
                        <div>
                            <h3 style="margin-bottom: 8px; font-weight: 500;">Laporan</h3>
                            <p style="font-size: 14px;">Menu untuk mengunduh laporan.</p>
                        </div>
                    </div>
                </div>

                <!-- PAGE: PENGATURAN -->
                <div id="page-pengaturan" class="content-section" style="display: none;">
                    <div
                        style="padding: 40px; border: 2px dashed #8b5cf6; border-radius: 16px; display: flex; align-items: center; justify-content: center; height: 400px; color: #8b5cf6; background-color: #f5f3ff; text-align: center;">
                        <div>
                            <h3 style="margin-bottom: 8px; font-weight: 500;">Pengaturan Sistem</h3>
                            <p style="font-size: 14px;">Konfigurasi aplikasi.</p>
                        </div>
                    </div>
                </div>
                <!-- MODAL FORM (Hidden by default) -->
                <div id="crud-modal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title"
                    role="dialog" aria-modal="true">
                    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
                        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"
                            onclick="closeModal()"></div>
                        <span class="hidden sm:inline-block sm:align-middle sm:h-screen"
                            aria-hidden="true">&#8203;</span>
                        <div
                            class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
                            <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                                <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4" id="modal-title">Form Data
                                    Karyawan</h3>
                                <form id="dataForm" onsubmit="saveData(event)">
                                    <input type="hidden" id="form-id">
                                    <div class="grid grid-cols-2 gap-4">
                                        <div class="col-span-1">
                                            <label class="block text-sm font-medium text-gray-700">SAP</label>
                                            <input type="text" id="form-sap" required
                                                class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                                        </div>
                                        <div class="col-span-1">
                                            <label class="block text-sm font-medium text-gray-700">Nama</label>
                                            <input type="text" id="form-nama" required
                                                class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                                        </div>
                                        <div class="col-span-1">
                                            <label class="block text-sm font-medium text-gray-700">Unit Kerja (Pos
                                                Code)</label>
                                            <input type="text" id="form-posCode"
                                                class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                                        </div>
                                        <div class="col-span-1">
                                            <label class="block text-sm font-medium text-gray-700">Item ID</label>
                                            <input type="text" id="form-itemId"
                                                class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                                        </div>
                                        <div class="col-span-2">
                                            <label class="block text-sm font-medium text-gray-700">Course Title</label>
                                            <input type="text" id="form-judul" required
                                                class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                                        </div>
                                        <div class="col-span-1">
                                            <label class="block text-sm font-medium text-gray-700">Periode</label>
                                            <input type="text" id="form-periode"
                                                class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                                        </div>
                                        <div class="col-span-1">
                                            <label class="block text-sm font-medium text-gray-700">Jumlah
                                                Anggaran</label>
                                            <input type="text" id="form-jumlah"
                                                class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                                        </div>
                                        <div class="col-span-1">
                                            <label class="block text-sm font-medium text-gray-700">Status
                                                Anggaran</label>
                                            <select id="form-statusAnggaran"
                                                class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                                                <option value="Tersedia">Tersedia</option>
                                                <option value="Tidak Tersedia">Tidak Tersedia</option>
                                            </select>
                                        </div>
                                        <div class="col-span-1">
                                            <label class="block text-sm font-medium text-gray-700">Mandatory</label>
                                            <select id="form-mandatory"
                                                class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                                                <option value="MANDATORY">MANDATORY</option>
                                                <option value="REGULASI">REGULASI</option>
                                            </select>
                                        </div>
                                        <div class="col-span-1">
                                            <label class="block text-sm font-medium text-gray-700">Risiko</label>
                                            <input type="text" id="form-resiko" placeholder="Tuliskan risiko..."
                                                class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                                        </div>
                                    </div>
                                    <div class="mt-5 sm:mt-6 sm:grid sm:grid-cols-2 sm:gap-3 sm:grid-flow-row-dense">
                                        <button type="submit"
                                            class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-indigo-600 text-base font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:col-start-2 sm:text-sm">
                                            Simpan
                                        </button>
                                        <button type="button" onclick="closeModal()"
                                            class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:col-start-1 sm:text-sm">
                                            Batal
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <script>
                // --- GLOBAL VARIABLES ---
                var GLOBAL_DATA = [];
                var CURRENT_TAB = 'all';

                // --- MOCK DATA FOR LOCAL DEV ---
                var MOCK_DATA_CLIENT = [
                    { id: '1', sap: '5252', nama: 'Mardiyah', posCode: 'POS-01', itemId: 'CERT-01', judul: 'Project Management Pro', periode: 'Jan 2026', statusAnggaran: 'Tersedia', jumlah: '15.000.000', mandatory: 'MANDATORY', resiko: 'Low' },
                    { id: '2', sap: '5252', nama: 'Mardiyah', posCode: 'POS-01', itemId: 'CERT-02', judul: 'Scrum Master', periode: 'Feb 2026', statusAnggaran: 'Tersedia', jumlah: '10.000.000', mandatory: 'REGULASI', resiko: 'Low' },
                    { id: '3', sap: '5253', nama: 'Ahmad Rizki', posCode: 'POS-02', itemId: 'CERT-03', judul: 'Cloud Architect', periode: 'Feb 2026', statusAnggaran: 'Tersedia', jumlah: '8.000.000', mandatory: 'REGULASI', resiko: 'Medium' },
                    { id: '4', sap: '5254', nama: 'Siti Nurhaliza', posCode: 'POS-03', itemId: 'CERT-04', judul: 'HR Professional', periode: 'Mar 2026', statusAnggaran: 'Tidak Tersedia', jumlah: '5.500.000', mandatory: 'MANDATORY', resiko: 'High' },
                    { id: '5', sap: '5254', nama: 'Siti Nurhaliza', posCode: 'POS-03', itemId: 'CERT-05', judul: 'People Analytics', periode: 'Mar 2026', statusAnggaran: 'Tersedia', jumlah: '3.500.000', mandatory: 'REGULASI', resiko: 'Medium' }
                ];

                // --- INITIALIZATION LOGIC ---
                document.addEventListener('DOMContentLoaded', function () {
                    console.log('DOM Ready. Starting initialization...');
                    window.isLoading = true;

                    // 1. SAFETY TIMEOUT
                    const retryBtn = document.getElementById('retry-button');
                    setTimeout(() => {
                        if (window.isLoading) {
                            console.warn('Server timeout. Showing manual retry.');
                            if (retryBtn) retryBtn.classList.remove('hidden');
                        }
                    }, 5000); // 5 seconds grace period

                    // 2. Determine Environment and Save
                    if (typeof google === 'undefined' || !google.script || !google.script.run) {
                        console.log('Local Environment detected. Loading mock data.');
                        initDashboard(MOCK_DATA_CLIENT);
                    } else {
                        console.log('Google Apps Script Environment detected. Fetching data...');
                        google.script.run
                            .withSuccessHandler((data) => {
                                console.log('Data received successfully.');
                                initDashboard(data);
                            })
                            .withFailureHandler((error) => {
                                console.error('Server failure:', error);
                                const container = document.getElementById('accordion-container');
                                if (container) container.innerHTML = '<div class="text-center p-8 text-red-500">Error: ' + error + '<br><button onclick="forceLoadOffline()" class="mt-4 px-4 py-2 bg-gray-100 rounded cursor-pointer">Load Offline Data</button></div>';
                            })
                            .getEmployeeData();
                    }
                });

                function forceLoadOffline() {
                    console.log("Forcing offline load");
                    if (typeof MOCK_DATA_CLIENT !== 'undefined') {
                        initDashboard(MOCK_DATA_CLIENT);
                    } else {
                        alert("Mock data not found!");
                    }
                }

                // --- CORE FUNCTIONS ---

                function onFailure(error) {
                    const container = document.getElementById('accordion-container');
                    if (container) {
                        container.innerHTML = `<div class="text-center text-red-500 py-8">Error: ${error.message || error}</div>`;
                    }
                }

                function initDashboard(data) {
                    try {
                        GLOBAL_DATA = data || [];
                        console.log('Initializing dashboard with ' + GLOBAL_DATA.length + ' records.');

                        // Populate Unit Filter
                        const unitSet = new Set(GLOBAL_DATA.map(r => r.posCode).filter(u => u));
                        const unitSelect = document.getElementById('filter-unit');
                        if (unitSelect) {
                            unitSelect.innerHTML = '<option value="">Semua Unit</option>';
                            Array.from(unitSet).sort().forEach(unit => {
                                const option = document.createElement('option');
                                option.value = unit;
                                option.textContent = unit;
                                unitSelect.appendChild(option);
                            });
                        }

                        renderAccordion(GLOBAL_DATA);
                        updateStats(GLOBAL_DATA); // Placeholder for stats update if needed
                    } catch (e) {
                        console.error('Render error:', e);
                        onFailure(e);
                    }
                }

                function updateStats(data) {
                    // Optional: Simple stat counters if IDs exist
                    const totalEl = document.getElementById('stat-total-karyawan');
                    if (totalEl) totalEl.innerText = new Set(data.map(r => r.sap)).size;

                    const certEl = document.getElementById('stat-total-sertifikat');
                    if (certEl) certEl.innerText = data.length;
                }

                // --- UI RENDERING functions ---

                function renderAccordion(data) {
                    const container = document.getElementById('accordion-container');
                    if (!container) return;

                    container.innerHTML = '';

                    if (!data || data.length === 0) {
                        container.innerHTML = '<div class="text-center text-gray-400 py-12 flex flex-col items-center"><svg class="h-10 w-10 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg><span>Tidak ada data ditemukan</span></div>';
                        return;
                    }

                    // Group by SAP
                    const groups = {};
                    data.forEach(row => {
                        const sap = row.sap || 'UNKNOWN';
                        if (!groups[sap]) {
                            groups[sap] = {
                                nama: row.nama || 'Tanpa Nama',
                                unitKerja: row.posCode || '-',
                                items: []
                            };
                        }
                        groups[sap].items.push(row);
                    });

                    // Render items
                    Object.keys(groups).sort().forEach(sap => {
                        const group = groups[sap];
                        const count = group.items.length;
                        const itemDiv = document.createElement('div');
                        itemDiv.className = 'bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden transition-all hover:shadow-md mb-2';

                        // Header (Clickable)
                        const suffix = sap.length > 2 ? sap.slice(-2) : sap;
                        itemDiv.innerHTML = `
                            <button onclick="toggleAccordion('${sap}')" class="w-full px-4 py-2 flex items-center bg-white hover:bg-gray-50 transition-colors focus:outline-none text-left">
                                <div class="w-8 flex-shrink-0 flex items-center">
                                    <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-indigo-50 text-indigo-600 font-bold text-xs border border-indigo-100">${suffix}</span>
                                </div>
                                <div class="flex-1 min-w-0 pr-4">
                                    <div class="flex items-center gap-2">
                                        <h3 class="text-sm font-bold text-gray-900 truncate">${group.nama}</h3>
                                        <span class="text-xs text-gray-400 font-mono">SAP: ${sap}</span>
                                    </div>
                                    <p class="text-xs text-gray-500 mt-0.5">${count} Kegiatan &bull; ${group.unitKerja}</p>
                                </div>
                                <div class="flex items-center ml-2">
                                    <svg id="icon-${sap}" class="transform transition-transform duration-200 h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                                    </svg>
                                </div>
                            </button>
                            <div id="content-${sap}" class="hidden border-t border-gray-100 bg-gray-50/50">
                                <div class="overflow-x-auto">
                                    <table class="min-w-full divide-y divide-gray-200">
                                        <thead class="bg-gray-50">
                                            <tr>
                                                <th class="px-2 py-2 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider pl-4">No</th>
                                                <th class="px-2 py-2 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">SAP</th>
                                                <th class="px-2 py-2 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Nama</th>
                                                <th class="px-2 py-2 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Item ID</th>
                                                <th class="px-2 py-2 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Course Title</th>
                                                <th class="px-2 py-2 text-left text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Rencana</th>
                                                <th class="px-2 py-2 text-right text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Anggaran</th>
                                                <th class="px-2 py-2 text-center text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                                                <th class="px-2 py-2 text-center text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Mandatory</th>
                                                <th class="px-2 py-2 text-center text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Risiko</th>
                                                <th class="px-2 py-2 text-center text-[10px] font-semibold text-gray-500 uppercase tracking-wider" style="width: 1%;">Aksi</th>
                                            </tr>
                                        </thead>
                                        <tbody class="bg-white divide-y divide-gray-200">
                                            ${group.items.map((r, index) => `
                                                <tr class="hover:bg-gray-50 transition-colors">
                                                    <td class="px-2 py-1 whitespace-nowrap text-[11px] text-center text-gray-500 pl-4">${index + 1}</td>
                                                    <td class="px-2 py-1 whitespace-nowrap text-[11px] text-gray-900">${r.sap}</td>
                                                    <td class="px-2 py-1 whitespace-nowrap text-[11px] text-gray-600">${r.nama}</td>
                                                    <td class="px-2 py-1 whitespace-nowrap text-[10px] text-gray-500 font-mono">${r.itemId}</td>
                                                    <td class="px-2 py-1 text-[11px] text-gray-900 font-medium max-w-xs truncate" title="${r.judul}">${r.judul}</td>
                                                    <td class="px-2 py-1 whitespace-nowrap text-[11px] text-gray-500">${r.periode}</td>
                                                    <td class="px-2 py-1 whitespace-nowrap text-[11px] text-gray-600 text-right font-mono">${r.jumlah}</td>
                                                    <td class="px-2 py-1 whitespace-nowrap text-center">
                                                        <span class="px-1.5 py-0.5 text-[10px] font-medium rounded-full ${r.statusAnggaran === 'Tersedia' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}">
                                                            ${r.statusAnggaran}
                                                        </span>
                                                    </td>
                                                    <td class="px-2 py-1 whitespace-nowrap text-[10px] text-center text-gray-600">
                                                        ${r.mandatory}
                                                    </td>
                                                    <td class="px-2 py-1 whitespace-nowrap text-center">
                                                        <span class="px-1.5 py-0.5 rounded text-[10px] border font-medium ${(r.resiko || '').toLowerCase().includes('high') || (r.resiko || '').toLowerCase().includes('tinggi') ? 'border-red-200 bg-red-50 text-red-600' :
                                ((r.resiko || '').toLowerCase().includes('medium') || (r.resiko || '').toLowerCase().includes('sedang') ? 'border-yellow-200 bg-yellow-50 text-yellow-600' :
                                    ((r.resiko || '').toLowerCase().includes('low') || (r.resiko || '').toLowerCase().includes('rendah') ? 'border-blue-200 bg-blue-50 text-blue-600' : 'border-gray-200 bg-gray-50 text-gray-600'))
                            }">
                                                            ${r.resiko || '-'}
                                                        </span>
                                                    </td>
                                            <td class="px-2 py-1 whitespace-nowrap text-center" style="width: 100px; min-width: 100px;">
                                                        <div class="flex justify-center items-center gap-2">
                                                            <!-- Tombol Edit (Biru) -->
                                                            <button type="button" onclick="handleEdit(event, '${r.id}')" class="flex items-center justify-center text-blue-700 hover:text-blue-900 transition-colors p-1.5 rounded bg-blue-100 hover:bg-blue-200 border border-blue-200 w-8 h-8" title="Edit Data">
                                                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                                                                    <path d="M21.731 2.269a2.625 2.625 0 00-3.712 0l-1.157 1.157 3.712 3.712 1.157-1.157a2.625 2.625 0 000-3.712zM19.513 8.199l-3.712-3.712-12.15 12.15a5.25 5.25 0 00-1.32 2.214l-.8 2.685a.75.75 0 00.933.933l2.685-.8a5.25 5.25 0 002.214-1.32L19.513 8.2z" />
                                                                </svg>
                                                            </button>
                                                            <!-- Tombol Hapus (Merah) -->
                                                            <button type="button" onclick="handleDelete(event, '${r.id}')" class="flex items-center justify-center text-red-700 hover:text-red-900 transition-colors p-1.5 rounded bg-red-100 hover:bg-red-200 border border-red-200 w-8 h-8" title="Hapus Data">
                                                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                                                                    <path fill-rule="evenodd" d="M16.5 4.478v.227a48.816 48.816 0 013.878.512.75.75 0 11-.49 1.478l-.56-.092.443 13.134A2.625 2.625 0 0117.155 22H6.845a2.625 2.625 0 01-2.617-2.261l.442-13.134-.56.092a.75.75 0 01-.49-1.478 48.818 48.818 0 013.878-.512v-.227c0-1.564 1.213-2.9 2.816-2.951a52.662 52.662 0 013.369 0c1.603.051 2.815 1.387 2.815 2.951zm-6.136-1.452a51.196 51.196 0 013.273 0C14.39 3.05 15 3.684 15 4.478v.113a49.488 49.488 0 00-6 0v-.113c0-.794.609-1.428 1.364-1.452zM10 8.5a.75.75 0 01.75.75v9.5a.75.75 0 01-1.5 0v-9.5A.75.75 0 0110 8.5zm4 0a.75.75 0 01.75.75v9.5a.75.75 0 01-1.5 0v-9.5A.75.75 0 0114 8.5z" clip-rule="evenodd" />
                                                                </svg>
                                                            </button>
                                                        </div>
                                                    </td>
                                                </tr>
                                            `).join('')}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        `;
                        container.appendChild(itemDiv);
                    });
                }

                function toggleAccordion(sap) {
                    const content = document.getElementById(`content-${sap}`);
                    const icon = document.getElementById(`icon-${sap}`);
                    if (!content) return;
                    if (content.classList.contains('hidden')) {
                        content.classList.remove('hidden');
                        if (icon) icon.classList.add('rotate-180');
                    } else {
                        content.classList.add('hidden');
                        if (icon) icon.classList.remove('rotate-180');
                    }
                }

                function handleEdit(event, id) {
                    event.stopPropagation();
                    openModal('edit', id);
                }

                function handleDelete(event, id) {
                    event.stopPropagation(); // STOP click from reaching parent
                    deleteItem(id);
                }

                // --- FILTER LOGIC ---
                function applyFilters() {
                    const searchInput = document.getElementById('searchInput');
                    const searchQuery = searchInput ? searchInput.value.toLowerCase() : "";
                    const unitFilter = document.getElementById('filter-unit');
                    const unitValue = unitFilter ? unitFilter.value : "";
                    const anggaranFilter = document.getElementById('filter-anggaran');
                    const anggaranValue = anggaranFilter ? anggaranFilter.value : "";

                    let filtered = GLOBAL_DATA.filter(r => {
                        if (CURRENT_TAB === 'active' && r.statusAnggaran !== 'Tersedia') return false;
                        if (CURRENT_TAB === 'expiring' && r.mandatory !== 'MANDATORY') return false;
                        if (CURRENT_TAB === 'inactive' && r.statusAnggaran !== 'Tidak Tersedia') return false;
                        if (CURRENT_TAB === 'renewal' && r.resiko !== 'High') return false;

                        const searchStr = (r.nama + " " + r.judul + " " + r.sap).toLowerCase();
                        if (searchQuery !== "" && !searchStr.includes(searchQuery)) return false;

                        if (unitValue !== "" && r.posCode !== unitValue) return false;
                        if (anggaranValue !== "" && r.statusAnggaran !== anggaranValue) return false;
                        return true;
                    });
                    renderAccordion(filtered);
                }

                function resetFilters() {
                    const search = document.getElementById('searchInput'); if (search) search.value = "";
                    const unit = document.getElementById('filter-unit'); if (unit) unit.value = "";
                    const angg = document.getElementById('filter-anggaran'); if (angg) angg.value = "";

                    const allTabBtn = document.querySelector("button[onclick*='all']");
                    if (allTabBtn) switchTab(allTabBtn, 'all');
                    else applyFilters();
                }

                function switchTab(btn, tabName) {
                    CURRENT_TAB = tabName;
                    document.querySelectorAll('.tab-btn').forEach(b => {
                        b.className = 'tab-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all bg-white text-gray-600 hover:text-gray-900 border border-gray-200 hover:border-gray-300';
                    });
                    btn.className = 'tab-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all bg-indigo-600 text-white shadow-sm ring-1 ring-indigo-600';
                    applyFilters();
                }

                // --- CRUD & MODAL LOGIC ---
                let isEditMode = false;

                function openModal(mode, dataOrId = null) {
                    const modal = document.getElementById('crud-modal');
                    const title = document.getElementById('modal-title');
                    const form = document.getElementById('dataForm');

                    modal.classList.remove('hidden');
                    isEditMode = mode === 'edit';
                    title.innerText = isEditMode ? 'Edit Data Karyawan' : 'Tambah Karyawan';

                    let data = dataOrId;
                    // FIX: If passed an ID string, find the object
                    if (isEditMode && typeof dataOrId === 'string') {
                        data = GLOBAL_DATA.find(r => r.id.toString() === dataOrId.toString());
                    }

                    if (isEditMode && data) {
                        try {
                            const setValue = (id, val) => {
                                const el = document.getElementById(id);
                                if (el) el.value = val || '';
                            };
                            setValue('form-id', data.id);
                            setValue('form-sap', data.sap);
                            setValue('form-nama', data.nama);
                            setValue('form-posCode', data.posCode);
                            setValue('form-itemId', data.itemId);
                            setValue('form-judul', data.judul);
                            setValue('form-periode', data.periode);
                            setValue('form-jumlah', data.jumlah);
                            setValue('form-statusAnggaran', data.statusAnggaran || 'Tersedia');
                            setValue('form-mandatory', data.mandatory || 'Mandatory');
                            setValue('form-resiko', data.resiko || 'Low');
                        } catch (e) { console.error("Error population form", e); }
                    } else {
                        form.reset();
                        if (document.getElementById('form-id')) document.getElementById('form-id').value = '';
                    }
                }

                function closeModal() {
                    const modal = document.getElementById('crud-modal');
                    if (modal) modal.classList.add('hidden');
                }

                function saveData(event) {
                    event.preventDefault();

                    const getValue = (id) => {
                        const el = document.getElementById(id);
                        return el ? el.value : '';
                    };

                    const formData = {
                        id: getValue('form-id'),
                        sap: getValue('form-sap'),
                        nama: getValue('form-nama'),
                        posCode: getValue('form-posCode'),
                        itemId: getValue('form-itemId'),
                        judul: getValue('form-judul'),
                        periode: getValue('form-periode'),
                        jumlah: getValue('form-jumlah'),
                        statusAnggaran: getValue('form-statusAnggaran'),
                        mandatory: getValue('form-mandatory'),
                        resiko: getValue('form-resiko')
                    };

                    const handler = isEditMode ? 'updateData' : 'addData';

                    if (typeof google !== 'undefined' && google.script && google.script.run) {
                        google.script.run.withSuccessHandler(data => {
                            closeModal();
                            initDashboard(data);
                        })[handler](formData);
                    } else {
                        // Local Mock
                        console.log('Saving locally...', formData);
                        let newData = [...GLOBAL_DATA];
                        if (isEditMode) {
                            const idx = newData.findIndex(r => r.id === formData.id);
                            if (idx !== -1) newData[idx] = { ...newData[idx], ...formData };
                        } else {
                            formData.id = Date.now().toString();
                            newData.push(formData);
                        }
                        closeModal();
                        initDashboard(newData);
                    }
                }

                function deleteItem(id) {
                    if (!confirm('Apakah Anda yakin ingin menghapus data ini?')) return;
                    if (typeof google !== 'undefined' && google.script && google.script.run) {
                        google.script.run.withSuccessHandler(data => {
                            initDashboard(data);
                        }).deleteData(id);
                    } else {
                        console.log('Deleting locally...', id);
                        const newData = GLOBAL_DATA.filter(r => r.id !== id);
                        initDashboard(newData);
                    }
                }
            </script>
</body>

</html>